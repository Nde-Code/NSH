# Cloudflare Workers runtime cache / build tooling
.wrangler/

# Node.js dependencies (auto-generated, very large, never commit)
node_modules/

# Production build output (compiled / bundled code)
dist/

# TypeScript configuration file generated by Wrangler
worker-configuration.d.ts

# Local environment variables (contains sensitive data, never commit)
.dev.vars

# Application or system logs (temporary debug files)
*.log

# macOS system metadata files (Finder metadata, safe to ignore)
.DS_Store

# Windows system thumbnail cache files
Thumbs.db